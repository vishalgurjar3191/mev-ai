# Firebase project config — get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenRouter powers AI Chat — free tier, no card required.
# Get a key at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=
# Any OpenRouter model id works. These are free-tier models:
# meta-llama/llama-3.1-8b-instruct:free | google/gemini-2.0-flash-exp:free | qwen/qwen-2.5-72b-instruct:free
VITE_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional: realistic, human-sounding voice for "Listen" / Voice Chat, powered by ElevenLabs.
# Free tier gives ~10,000 characters/month. Without this key, the app falls back to your
# phone/browser's built-in (more robotic) text-to-speech — everything still works either way.
# Get a free key at https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=
